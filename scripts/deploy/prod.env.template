# =============================================================================
# CodePilot 生产环境配置模板
# 使用方式: 复制此文件并填入真实值
#   cp prod.env.template prod.env && vim prod.env
#
# 注意: 所有标记 [必填] 的项必须配置，否则后端启动时会报错
#       所有 *_SECRET 字段必须使用 >= 32 字节的随机字符串
# =============================================================================

# ======================== 数据库 (PostgreSQL 16 + pgvector) ========================
# [必填] JDBC 连接地址
CODEPILOT_DB_URL=jdbc:postgresql://YOUR_PG_HOST:5432/codepilot
# [必填] 数据库用户名
CODEPILOT_DB_USER=codepilot
# [必填] 数据库密码
CODEPILOT_DB_PASSWORD=CHANGE_ME_DB_PASSWORD
# [可选] HikariCP 最大连接数 (默认: 40)
CODEPILOT_DB_POOL_MAX=40

# ======================== Redis ========================
# [必填] Redis 连接 URL
CODEPILOT_REDIS_URL=redis://YOUR_REDIS_HOST:6379

# ======================== LLM 服务 (OpenAI 协议兼容) ========================
# [必填] LLM 服务基地址
CODEPILOT_LLM_BASE_URL=https://api.openai.com/v1
# [必填] LLM API Key
CODEPILOT_LLM_API_KEY=sk-CHANGE_ME_LLM_API_KEY
# [必填] 默认模型名
CODEPILOT_LLM_DEFAULT_MODEL=gpt-4o-mini

# ======================== 安全与鉴权 ========================
# [必填] JWT 签名密钥 (>= 32 字节 URL-safe 随机字符串)
CODEPILOT_JWT_SECRET=CHANGE_ME_JWT_SECRET_32_BYTES_MIN
# [必填] HMAC 签名密钥 (>= 32 字节 URL-safe 随机字符串)
CODEPILOT_HMAC_SECRET=CHANGE_ME_HMAC_SECRET_32_BYTES_MIN

# ======================== SSO 认证 (三选一或组合) ========================
# --- (A) OIDC (生产推荐) ---
CODEPILOT_OIDC_ISSUER=
CODEPILOT_OIDC_JWKS_URI=
CODEPILOT_OIDC_AUDIENCE=codepilot
CODEPILOT_OIDC_DEVICE_AUTH_ENDPOINT=
CODEPILOT_OIDC_TOKEN_ENDPOINT=
CODEPILOT_OIDC_CLIENT_ID=
CODEPILOT_OIDC_CLIENT_SECRET=
CODEPILOT_OIDC_SCOPE=openid profile email offline_access

# --- (B) 企业 SSO 桥 (HMAC) ---
CODEPILOT_SSO_BRIDGE_SECRET=

# --- (C) Dev 登录 (仅开发环境，生产必须为 false) ---
CODEPILOT_SSO_DEV_ENABLED=false
CODEPILOT_SSO_DEV_TOKEN=

# ======================== 可观测性 ========================
# [可选] OpenTelemetry Collector OTLP 端点
OTEL_EXPORTER_OTLP_ENDPOINT=

# ======================== 服务端口 ========================
# [可选] 监听端口 (默认: 8080)
CODEPILOT_PORT=8080

# ======================== Docker Compose 专用 (postgres 容器) ========================
POSTGRES_DB=codepilot
POSTGRES_USER=codepilot
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD