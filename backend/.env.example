# Copy to backend/.env and fill real values; never commit secrets.

# -- Database (PostgreSQL 16 + pgvector) --
CODEPILOT_DB_URL=jdbc:postgresql://localhost:5432/codepilot
CODEPILOT_DB_USER=codepilot
CODEPILOT_DB_PASSWORD=codepilot
CODEPILOT_DB_POOL_MAX=40

# -- Redis --
CODEPILOT_REDIS_URL=redis://localhost:6379

# -- LLM provider (OpenAI-compatible) --
CODEPILOT_LLM_BASE_URL=https://api.openai.com/v1
CODEPILOT_LLM_API_KEY=sk-replace-me
CODEPILOT_LLM_DEFAULT_MODEL=gpt-4o-mini

# -- Security --
# 32-byte-equivalent URL-safe random; rotate on leak.
CODEPILOT_JWT_SECRET=replace-with-32-byte-urlsafe-random
CODEPILOT_HMAC_SECRET=replace-with-32-byte-urlsafe-random

# -- SSO -- choose ONE OR MORE methods; details in docs/01-架构设计.md and DEPLOY.md.

# (A) Production: OIDC. If 'issuer' is non-empty, OIDC takes priority.
CODEPILOT_OIDC_ISSUER=
CODEPILOT_OIDC_JWKS_URI=
CODEPILOT_OIDC_AUDIENCE=codepilot
CODEPILOT_OIDC_JWKS_TTL=15m
# Device Authorization Flow (RFC 8628) — used by the IDE plugin to log users in.
CODEPILOT_OIDC_DEVICE_AUTH_ENDPOINT=
CODEPILOT_OIDC_TOKEN_ENDPOINT=
CODEPILOT_OIDC_CLIENT_ID=
CODEPILOT_OIDC_CLIENT_SECRET=
CODEPILOT_OIDC_SCOPE=openid profile email offline_access

# (B) Corporate SSO bridge: HMAC bootstrap token signed by your in-house adapter.
#     Leave empty to disable. ≥ 32 bytes when set.
CODEPILOT_SSO_BRIDGE_SECRET=

# (C) Dev-only login (only takes effect when active profile contains 'dev'):
#     POST /v1/auth/login  body: {"ssoToken":"<dev-token>:<userId>:<tenant>:<device>"}
CODEPILOT_SSO_DEV_ENABLED=false
CODEPILOT_SSO_DEV_TOKEN=

# -- Observability --
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# -- Port --
CODEPILOT_PORT=8080