<idea-plugin>
  <id>io.codepilot.intellij</id>
  <name>CodePilot</name>
  <vendor>CodePilot</vendor>

  <resource-bundle>messages.CodePilotBundle</resource-bundle>

  <depends>com.intellij.modules.platform</depends>
  <depends optional="true" config-file="codepilot-git.xml">Git4Idea</depends>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="io.codepilot.plugin.settings.CodePilotSettings"/>
    <applicationService serviceImplementation="io.codepilot.plugin.transport.HttpClientService"/>
    <applicationService serviceImplementation="io.codepilot.plugin.auth.AuthService"/>
    <applicationService serviceImplementation="io.codepilot.plugin.auth.LoginService"/>
    <applicationService serviceImplementation="io.codepilot.plugin.session.SessionStore"/>
    <applicationService serviceImplementation="io.codepilot.plugin.update.UpdateService"/>
    <applicationService serviceImplementation="io.codepilot.plugin.update.HotPatchService"/>
    <applicationService serviceImplementation="io.codepilot.plugin.update.RuntimeResourceRegistry"/>
    <applicationService serviceImplementation="io.codepilot.plugin.marketplace.LocalMarketplaceStore"/>
    <applicationService serviceImplementation="io.codepilot.plugin.mcp.McpProcessManager"/>

    <!-- Project-level services -->
    <projectService serviceImplementation="io.codepilot.plugin.toolwindow.CefChatPanelRegistry"/>
    <projectService serviceImplementation="io.codepilot.plugin.indexer.IndexWatcher"/>
    <projectService serviceImplementation="io.codepilot.plugin.indexer.IndexScheduler"/>
    <projectService serviceImplementation="io.codepilot.plugin.context.AtReferenceProvider"/>
    <projectService serviceImplementation="io.codepilot.plugin.context.ProjectRulesLoader"/>
    <projectService serviceImplementation="io.codepilot.plugin.tools.TerminalSessionManager"/>

    <applicationConfigurable
        parentId="tools"
        id="io.codepilot.settings"
        instance="io.codepilot.plugin.settings.CodePilotConfigurable"
        displayName="CodePilot"/>

    <toolWindow id="CodePilot"
                anchor="right"
                icon="AllIcons.Toolwindows.ToolWindowMessages"
                factoryClass="io.codepilot.plugin.toolwindow.CodePilotToolWindowFactory"/>

    <postStartupActivity implementation="io.codepilot.plugin.startup.CodePilotStartupActivity"/>
    <postStartupActivity implementation="io.codepilot.plugin.keymap.CodePilotKeymap"/>
    <notificationGroup id="CodePilot" displayType="BALLOON"/>

    <inlineCompletionProvider id="CodePilot"
                              implementation="io.codepilot.plugin.completion.CodePilotInlineCompletionProvider"/>
  </extensions>

  <actions resource-bundle="messages.CodePilotBundle">
    <!-- ===== Unified CodePilot group — registered in all right-click menus =====
         Text/description for actions and groups come from CodePilotBundle.properties
         (action.<id>.text / group.<id>.text); do not use text="%key" here — it is not
         resolved for <action>/<group> and would show literally in the UI. -->
    <group id="CodePilot.MainGroup" popup="true">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
    </group>

    <!-- Add to Chat / Add to New Chat — top-level (not inside popup, always visible) -->
    <action id="CodePilot.AddToChat"
            class="io.codepilot.plugin.actions.AddToChatAction">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
      <keyboard-shortcut first-keystroke="control L" keymap="$default"/>
    </action>

    <action id="CodePilot.AddToNewChat"
            class="io.codepilot.plugin.actions.AddToNewChatAction">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
    </action>

    <!-- Actions inside the CodePilot popup group -->
    <action id="CodePilot.Refactor"
            class="io.codepilot.plugin.actions.RefactorAction">
      <add-to-group group-id="CodePilot.MainGroup" anchor="last"/>
      <keyboard-shortcut first-keystroke="control alt R" keymap="$default"/>
      <keyboard-shortcut first-keystroke="meta alt R" keymap="Mac OS X 10.5+"/>
    </action>
    <action id="CodePilot.Review"
            class="io.codepilot.plugin.actions.ReviewAction">
      <add-to-group group-id="CodePilot.MainGroup" anchor="last"/>
      <keyboard-shortcut first-keystroke="control alt V" keymap="$default"/>
    </action>
    <action id="CodePilot.Comment"
            class="io.codepilot.plugin.actions.CommentAction">
      <add-to-group group-id="CodePilot.MainGroup" anchor="last"/>
    </action>
    <action id="CodePilot.GenTest"
            class="io.codepilot.plugin.actions.GenTestAction">
      <add-to-group group-id="CodePilot.MainGroup" anchor="last"/>
      <keyboard-shortcut first-keystroke="control alt T" keymap="$default"/>
    </action>
    <action id="CodePilot.GenDoc"
            class="io.codepilot.plugin.actions.GenDocAction">
      <add-to-group group-id="CodePilot.MainGroup" anchor="last"/>
    </action>

    <!-- PSI element (class/method) right-click -->
    <group id="CodePilot.PsiElementActions" popup="true">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </group>

    <action id="CodePilot.PsiGenTest"
            class="io.codepilot.plugin.actions.PsiGenTestAction">
      <add-to-group group-id="CodePilot.PsiElementActions" anchor="last"/>
    </action>
    <action id="CodePilot.PsiGenDoc"
            class="io.codepilot.plugin.actions.PsiGenDocAction">
      <add-to-group group-id="CodePilot.PsiElementActions" anchor="last"/>
    </action>
    <action id="CodePilot.PsiComment"
            class="io.codepilot.plugin.actions.PsiCommentAction">
      <add-to-group group-id="CodePilot.PsiElementActions" anchor="last"/>
    </action>

    <!-- P0-04 Inline Edit (Cmd+K) and Accept/Reject/Rewrite shortcuts. The
         Accept/Reject/Rewrite actions are only enabled while an InlineEditSession
         exists for the active editor (see InlineEditController.sessionFor). -->
    <action id="CodePilot.InlineEdit"
            class="io.codepilot.plugin.inline.InlineEditAction"
            text="CodePilot Inline Edit"
            description="Describe an inline edit for the selected code">
      <keyboard-shortcut first-keystroke="control K" keymap="$default"/>
      <keyboard-shortcut first-keystroke="meta K" keymap="Mac OS X 10.5+"/>
    </action>
    <action id="CodePilot.InlineEdit.Accept"
            class="io.codepilot.plugin.inline.AcceptInlineEditAction"
            text="CodePilot Inline Edit: Accept">
      <keyboard-shortcut first-keystroke="alt Y" keymap="$default"/>
    </action>
    <action id="CodePilot.InlineEdit.Reject"
            class="io.codepilot.plugin.inline.RejectInlineEditAction"
            text="CodePilot Inline Edit: Reject">
      <keyboard-shortcut first-keystroke="alt N" keymap="$default"/>
    </action>
    <action id="CodePilot.InlineEdit.Rewrite"
            class="io.codepilot.plugin.inline.RewriteInlineEditAction"
            text="CodePilot Inline Edit: Rewrite">
      <keyboard-shortcut first-keystroke="alt R" keymap="$default"/>
    </action>

    <action id="CodePilot.Tab.Accept"
            class="io.codepilot.plugin.completion.AcceptCodePilotTabSuggestionAction"
            text="CodePilot Tab: Accept Next Suggestion">
      <keyboard-shortcut first-keystroke="TAB" keymap="$default"/>
      <keyboard-shortcut first-keystroke="TAB" keymap="Mac OS X 10.5+"/>
      <keyboard-shortcut first-keystroke="alt ENTER" keymap="$default"/>
      <keyboard-shortcut first-keystroke="alt ENTER" keymap="Mac OS X 10.5+"/>
    </action>
    <action id="CodePilot.Tab.Dismiss"
            class="io.codepilot.plugin.completion.DismissCodePilotTabSuggestionAction"
            text="CodePilot Tab: Dismiss Suggestion">
      <keyboard-shortcut first-keystroke="ESCAPE" keymap="$default"/>
      <keyboard-shortcut first-keystroke="ESCAPE" keymap="Mac OS X 10.5+"/>
    </action>

    <action id="CodePilot.OpenChat"
            class="io.codepilot.plugin.actions.OpenChatAction"
            text="Open CodePilot chat">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
      <keyboard-shortcut first-keystroke="control shift L" keymap="$default"/>
    </action>

    <action id="CodePilot.SignIn" class="io.codepilot.plugin.auth.SignInAction" text="CodePilot: Sign in">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
    <action id="CodePilot.Reset.Soft"  class="io.codepilot.plugin.reset.SoftResetAction"  text="CodePilot: Reset (soft)"/>
    <action id="CodePilot.Reset.Hard"  class="io.codepilot.plugin.reset.HardResetAction"  text="CodePilot: Reset (hard, restart)"/>
    <action id="CodePilot.CheckUpdate" class="io.codepilot.plugin.update.CheckUpdateAction" text="CodePilot: Check for updates"/>
    <action id="CodePilot.RollbackToPreviousVersion" class="io.codepilot.plugin.update.RollbackAction" text="CodePilot: Rollback to previous version"/>
  </actions>
</idea-plugin>